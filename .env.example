# Docker Compose 运行时环境变量（可选覆盖默认值）

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL_NAME=myqwen:latest

SANDBOX_DOCKER_IMAGE=gcc:13
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_QUOTA=50000
SANDBOX_TIMEOUT_SECONDS=5

SUBMISSION_TTL_MINUTES=15
MAX_SUBMISSIONS_IN_MEMORY=300

ALLOWED_LANGUAGES=cpp
MAX_SOURCE_CODE_LENGTH=20000
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20

LOG_LEVEL=INFO
